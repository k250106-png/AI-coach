# ===== FIREBASE AUTHENTICATION =====
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ===== BACKEND =====
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
# Production: https://api.vetto-ai.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ===== RATE LIMITING (Optional - Redis) =====
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# ===== AI MODELS =====
NEXT_PUBLIC_GEMINI_MODEL=gemini-2.0-flash
# Keep API keys on backend only (not NEXT_PUBLIC_)

# ===== BASE URL =====
NEXT_PUBLIC_BASE_URL=https://vetto-ai.com
# For development: http://localhost:3000

# ===== ANALYTICS =====
NEXT_PUBLIC_GA_ID=your_google_analytics_id

# ===== ENVIRONMENT =====
NODE_ENV=development
# Options: development, production

# ===== INTERVIEW CONFIGURATION =====
NEXT_PUBLIC_ENABLE_DIFFICULTY_PROGRESSION=true
NEXT_PUBLIC_ENABLE_CODING_ROUNDS=true
NEXT_PUBLIC_ENABLE_MULTI_ROUND_MODE=true
NEXT_PUBLIC_ENABLE_TIME_PRESSURE=true
NEXT_PUBLIC_ENABLE_ADAPTIVE_DIFFICULTY=true

# ===== FEATURE FLAGS =====
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_DEMO=true
